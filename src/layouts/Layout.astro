---
import "../styles/global.css";
import { getSiteConfig } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "个人中心",
  description = "个人网站中心页面",
} = Astro.props;

const config = getSiteConfig();
const { background } = config;
---

<!doctype html>
<html lang="zh-CN" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      // 避免主题加载闪烁 (FOUC)
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      };
      const theme = getThemePreference();
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <!-- 全局背景层 -->
    <div class="fixed inset-0 -z-10 overflow-hidden select-none pointer-events-none">
      <img
        src={background.src}
        alt=""
        aria-hidden="true"
        class="h-full w-full object-cover transition-opacity duration-500"
        loading="eager"
      />
      <!-- 背景遮罩 (随主题色切换底色) -->
      <div
        class="background-overlay absolute inset-0 bg-background transition-colors duration-300"
        style={`opacity: ${background.overlay}`}
      >
      </div>
      <!-- 扫描线纹理 -->
      <div class="scan-lines absolute inset-0 pointer-events-none" aria-hidden="true"></div>
    </div>

    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    height: 100%;
    margin: 0;
  }

  /* 浅色模式：高遮罩浓度保证深色文字可读 */
  html:not(.dark) .background-overlay {
    opacity: 0.82 !important;
  }

  /* 暗色模式：虚空压在亮背景图上，提浓遮罩并轻虚化，
     既压住亮度峰值让灰字可读，又保留背景图的色温氛围 */
  html.dark .background-overlay {
    opacity: 0.72 !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  </style>
