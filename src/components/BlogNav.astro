---
/**
 * 博客导航栏
 *
 * 薄型固定顶栏，包含站点标题和博客链接。
 * @component BlogNav
 */

import { getSiteConfig } from "@/lib/site";

interface Props {
  current?: "home" | "blog";
}

const { current } = Astro.props;
const { site } = getSiteConfig();
---

<nav class="fixed top-0 left-0 right-0 z-50 flex h-12 items-center justify-between border-b border-border/40 bg-background/70 px-6 backdrop-blur md:px-12">
  <a
    href="/"
    class="font-heading text-sm font-semibold tracking-tight text-foreground transition-colors hover:text-primary"
  >
    {site.title}
  </a>
  <a
    href="/blog"
    class="relative text-xs uppercase tracking-[0.15em] transition-colors hover:text-accent"
    class:list={{
      "text-accent": current === "blog",
      "text-muted-foreground": current !== "blog",
    }}
  >
    博客
    {current === "blog" && (
      <span class="absolute -bottom-[13px] left-1/2 h-px w-4 -translate-x-1/2 bg-accent"></span>
    )}
  </a>
</nav>
