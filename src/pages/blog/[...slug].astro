---
/**
 * 博客文章详情页
 *
 * 动态路由，为每篇已发布的文章生成独立页面。
 * @route /blog/:slug
 */

import Layout from "@/layouts/Layout.astro";
import BlogNav from "@/components/astro/BlogNav.astro";
import Comments from "@/components/react/Comments.tsx";
import CodeBlockEnhancer from "@/components/react/CodeBlockEnhancer.tsx";
import ReadingNav from "@/components/react/ReadingNav.tsx";
import {
  getPublishedPosts,
  getAdjacentPosts,
  formatDate,
  readingTime,
} from "@/lib/blog";
import { getSiteConfig } from "@/lib/site";
import { render } from "astro:content";
import type { BlogPost } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: BlogPost };
const { Content, headings } = await render(post);
const minutes = readingTime(post.body ?? "");
const { comments } = getSiteConfig();

// 相邻文章（较新 / 较旧），用于底部上下篇导航
const allPosts = await getPublishedPosts();
const { newer, older } = getAdjacentPosts(allPosts, post.id);
---

<Layout title={`${post.data.title} · 博客`} description={post.data.description}>
  <BlogNav current="blog" />

  <main class="relative pt-12">
    <article class="mx-auto max-w-2xl px-6 py-16">
      <!-- 文章头部 -->
      <header>
        <div
          class="text-muted-foreground flex flex-wrap items-center gap-3 text-xs"
        >
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          <span aria-hidden="true">&middot;</span>
          <span>{minutes} 分钟阅读</span>
          {
            post.data.tags.length > 0 && (
              <>
                <span aria-hidden="true">&middot;</span>
                <ul class="flex flex-wrap gap-1.5">
                  {post.data.tags.map((tag: string) => (
                    <li class="border-border/40 bg-card text-muted-foreground rounded-full border px-2 py-0.5 text-[10px] tracking-[0.08em] uppercase">
                      {tag}
                    </li>
                  ))}
                </ul>
              </>
            )
          }
        </div>
        <h1
          class="font-heading text-foreground mt-4 text-3xl font-semibold tracking-tight"
        >
          {post.data.title}
        </h1>
        <p class="text-muted-foreground mt-2 text-sm">
          {post.data.description}
        </p>
      </header>

      <!-- 裂隙装饰线 -->
      <div class="rift-line my-10 h-0.5 w-full"></div>

      <!-- 文章正文 -->
      <div class="prose-rift">
        <Content />
      </div>

      <!-- 代码块增强：复制按钮 + 长代码折叠 -->
      <CodeBlockEnhancer client:load />

      <!-- 上一篇 / 下一篇导航 -->
      <nav class="border-border/40 mt-16 border-t pt-8">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {/* 较新的一篇（上一篇） */}
          {
            newer ? (
              <a
                href={`/blog/${newer.id}`}
                class="group border-border/40 bg-card/40 hover:border-accent/50 hover:bg-card/70 flex flex-col gap-1 rounded-lg border px-4 py-3 transition-colors"
              >
                <span class="text-muted-foreground text-[10px] tracking-[0.15em] uppercase">
                  <span aria-hidden="true">&larr;</span> 较新
                </span>
                <span class="text-foreground group-hover:text-accent line-clamp-1 text-sm font-medium transition-colors">
                  {newer.data.title}
                </span>
              </a>
            ) : (
              <span class="hidden sm:block" />
            )
          }

          {/* 较旧的一篇（下一篇） */}
          {
            older ? (
              <a
                href={`/blog/${older.id}`}
                class="group border-border/40 bg-card/40 hover:border-accent/50 hover:bg-card/70 flex flex-col gap-1 rounded-lg border px-4 py-3 text-right transition-colors sm:col-start-2"
              >
                <span class="text-muted-foreground text-[10px] tracking-[0.15em] uppercase">
                  较旧 <span aria-hidden="true">&rarr;</span>
                </span>
                <span class="text-foreground group-hover:text-accent line-clamp-1 text-sm font-medium transition-colors">
                  {older.data.title}
                </span>
              </a>
            ) : (
              <span class="hidden sm:block" />
            )
          }
        </div>

        <a
          href="/blog"
          class="text-muted-foreground hover:text-accent mt-6 inline-flex items-center gap-1 text-sm transition-colors"
        >
          <span aria-hidden="true">&larr;</span>
          返回博客
        </a>
      </nav>

      <!-- 评论系统（滚动进入视口后懒加载） -->
      <Comments config={comments} client:visible />
    </article>
  </main>

  <!-- 阅读导航：右下角悬浮目录 + 回到顶部 -->
  <ReadingNav {headings} client:load />
</Layout>
