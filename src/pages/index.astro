---
import Layout from "@/layouts/Layout.astro";
import InfoCard from "@/components/react/InfoCard.tsx";
import SocialLinks from "@/components/react/SocialLinks.tsx";
import Typewriter from "@/components/react/Typewriter.tsx";
import ThemeToggle from "@/components/astro/ThemeToggle.astro";
import { getSiteConfig } from "@/lib/site";

const config = getSiteConfig();
const { avatar, info, hitokoto, social, site } = config;
---

<Layout title={site.title} description={avatar.tagline}>
  <!-- 顶部主题切换浮动按钮 -->
  <div class="fixed top-4 right-6 z-50 flex items-center gap-3">
    <ThemeToggle />
  </div>

  <!-- 主内容 -->
  <main
    class="relative mx-auto flex min-h-screen max-w-4xl flex-col items-center justify-center px-6 py-20"
  >
    <!-- 三栏布局：左信息 · 中头像 · 右信息 -->
    <div
      class="grid w-full grid-cols-1 items-center gap-10 md:grid-cols-[1fr_auto_1fr] md:gap-12"
    >
      <!-- 左侧词条 -->
      <ul class="order-2 flex flex-col gap-3 md:order-1 md:items-end">
        {
          info.left.map((item, i) => (
            <InfoCard item={item} side="left" index={i} client:load />
          ))
        }
      </ul>

      <!-- 中心头像 -->
      <div class="order-1 flex flex-col items-center gap-6 md:order-2">
        <div class="rift-ring relative">
          <!-- 光晕 -->
          <div
            class="rift-glow absolute -inset-3 rounded-full opacity-40 blur-xl"
          >
          </div>
          <!-- 旋转边框 -->
          <div class="rift-border absolute -inset-[3px] rounded-full"></div>
          <img
            src={avatar.src}
            alt={avatar.alt}
            class="border-background animate-in fade-in zoom-in-105 fill-mode-both relative h-36 w-36 rounded-full border-[3px] object-cover shadow-2xl duration-700"
            loading="eager"
          />
        </div>
        <div
          class="animate-in fade-in slide-in-from-bottom-4 fill-mode-both flex flex-col items-center gap-1.5 duration-700 [animation-delay:300ms]"
        >
          <h1
            class="font-heading text-foreground text-2xl font-semibold tracking-tight"
          >
            {avatar.name}
          </h1>
          <p class="text-muted-foreground text-sm">{avatar.tagline}</p>
        </div>
      </div>

      <!-- 右侧词条 -->
      <ul class="order-3 flex flex-col gap-3 md:items-start">
        {
          info.right.map((item, i) => (
            <InfoCard item={item} side="right" index={i} client:load />
          ))
        }
      </ul>
    </div>

    <!-- 一言打字效果 -->
    {
      hitokoto.enabled && (
        <div class="animate-in fade-in slide-in-from-bottom-3 fill-mode-both mt-14 flex min-h-[2rem] w-full max-w-xl items-center justify-center px-4 text-center duration-700 [animation-delay:700ms]">
          <Typewriter
            placeholder={hitokoto.placeholder}
            fallback={hitokoto.fallback}
            typeSpeed={hitokoto.typeSpeed}
            deleteSpeed={hitokoto.deleteSpeed}
            holdAfterTyped={hitokoto.holdAfterTyped}
            holdAfterDeleted={hitokoto.holdAfterDeleted}
            client:load
          />
        </div>
      )
    }

    <!-- 社交链接 -->
    {
      social.length > 0 && (
        <div class="animate-in fade-in slide-in-from-bottom-3 fill-mode-both mt-10 duration-700 [animation-delay:900ms]">
          <SocialLinks links={social} client:load />
        </div>
      )
    }

    <!-- 博客链接 -->
    <a
      href="/blog"
      class="text-muted-foreground hover:text-accent animate-in fade-in slide-in-from-bottom-3 fill-mode-both mt-6 inline-flex items-center gap-1.5 text-xs tracking-[0.2em] uppercase transition-colors duration-700 [animation-delay:1100ms]"
    >
      博客 / Blog
    </a>
  </main>
</Layout>

<style>
  /* ===== Rift Ring – 维度裂隙旋转光环 ===== */

  /* 柔光晕 */
  .rift-glow {
    background: conic-gradient(
      from var(--rift-angle, 0deg),
      oklch(0.58 0.22 18),
      oklch(0.72 0.12 180),
      oklch(0.58 0.22 18)
    );
    animation: rift-spin 8s linear infinite;
  }

  /* 旋转边框环 */
  .rift-border {
    background: conic-gradient(
      from var(--rift-angle, 0deg),
      oklch(0.58 0.22 18),
      oklch(0.72 0.12 180),
      oklch(0.58 0.22 18)
    );
    /* 用 mask 只保留外圈 3px 环形 */
    -webkit-mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 3px),
      #000 calc(100% - 2.5px)
    );
    mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 3px),
      #000 calc(100% - 2.5px)
    );
    animation: rift-spin 8s linear infinite;
  }

  /* rift-spin keyframe 的真源在 global.css（全局版本，供 .rift-line / .rift-underline
     / .toc-rift-bar 等使用）。此处因 Astro scoped <style> 会改写 keyframe 名以隔离，
     需保留一份本地定义供 .rift-glow / .rift-border 引用，两者语义一致。 */
  @keyframes rift-spin {
    to {
      --rift-angle: 360deg;
    }
  }

  /* 悬停时光晕增强 */
  .rift-ring:hover .rift-glow {
    opacity: 0.65;
    filter: blur(28px);
  }

  /* 外圈呼吸环 */
  .rift-ring::before {
    content: "";
    position: absolute;
    inset: -10px;
    border-radius: 9999px;
    border: 1px solid oklch(0.93 0.01 90 / 0.1);
    animation: ring-breathe 5s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes ring-breathe {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.3;
    }
    50% {
      transform: scale(1.06);
      opacity: 0.6;
    }
  }

  /* 打字光标闪烁 */
  :global(.typewriter-cursor.is-blink) {
    animation: cursor-blink 1.05s steps(1) infinite;
  }

  @keyframes cursor-blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rift-glow,
    .rift-border {
      animation: none;
    }
    .rift-ring::before {
      animation: none;
    }
  }
</style>
