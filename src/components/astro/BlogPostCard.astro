---
/**
 * 博客文章卡片
 *
 * 用于博客列表页，展示文章的日期、标题、描述和标签。
 * @component BlogPostCard
 */

import type { BlogPost } from "@/lib/blog";
import { formatDate } from "@/lib/blog";

interface Props {
  post: BlogPost;
  index: number;
}

const { post, index } = Astro.props;
---

<a
  href={`/blog/${post.id}`}
  class="group block rounded-xl border border-border/40 bg-card/50 p-5 transition-all duration-300 hover:border-primary/40 hover:bg-card/80 animate-in fade-in slide-in-from-bottom-4 duration-600 fill-mode-both"
  style={`animation-delay:${index * 80}ms`}
>
  <div class="flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
    <time datetime={post.data.pubDate.toISOString()}>
      {formatDate(post.data.pubDate)}
    </time>
    {post.data.tags.length > 0 && (
      <ul class="flex flex-wrap gap-1.5">
        {post.data.tags.map((tag: string) => (
          <li
            class="rounded-full border border-border/40 bg-card px-2 py-0.5 text-[10px] uppercase tracking-[0.08em] text-muted-foreground"
          >
            {tag}
          </li>
        ))}
      </ul>
    )}
  </div>
  <h2 class="mt-2 font-heading text-lg font-semibold text-foreground transition-colors duration-300 group-hover:text-primary">
    {post.data.title}
  </h2>
  <p class="mt-1.5 line-clamp-2 text-sm text-muted-foreground">
    {post.data.description}
  </p>
</a>
