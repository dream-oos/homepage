---
import Layout from "@/layouts/Layout.astro";
import InfoCard from "@/components/InfoCard.tsx";
import SocialLinks from "@/components/SocialLinks.tsx";
import Typewriter from "@/components/Typewriter.tsx";
import { getSiteConfig } from "@/lib/site";

const config = getSiteConfig();
const { avatar, background, info, hitokoto, social, site } = config;
---

<Layout title={site.title} description={avatar.tagline}>
  <!-- 背景层 -->
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <img
      src={background.src}
      alt=""
      aria-hidden="true"
      class="h-full w-full object-cover"
      loading="eager"
    />
    <div
      class="absolute inset-0 bg-background"
      style={`opacity: ${background.overlay}`}
    >
    </div>
  </div>

  <!-- 主内容 -->
  <main class="relative mx-auto flex min-h-screen max-w-5xl flex-col items-center justify-center px-6 py-16">
    <!-- 三栏布局：左信息 · 中头像 · 右信息 -->
    <div
      class="grid w-full grid-cols-1 items-center gap-10 md:grid-cols-[1fr_auto_1fr] md:gap-8"
    >
      <!-- 左侧词条 -->
      <ul class="order-2 flex flex-col gap-3 md:order-1 md:items-end">
        {info.left.map((item, i) => (
          <InfoCard item={item} side="left" index={i} client:load />
        ))}
      </ul>

      <!-- 中心头像 -->
      <div class="order-1 flex flex-col items-center gap-5 md:order-2">
        <div class="avatar-ring relative">
          <div class="absolute -inset-1 rounded-full bg-gradient-to-tr from-indigo-500 via-fuchsia-500 to-pink-500 opacity-70 blur-md animate-in fade-in zoom-in-105 duration-1000 fill-mode-both">
          </div>
          <img
            src={avatar.src}
            alt={avatar.alt}
            class="relative h-36 w-36 rounded-full border-4 border-background/80 object-cover shadow-2xl animate-in fade-in zoom-in-110 duration-700 fill-mode-both"
            loading="eager"
          />
        </div>
        <div class="flex flex-col items-center gap-1 animate-in fade-in slide-in-from-bottom-4 duration-700 fill-mode-both [animation-delay:300ms]">
          <h1 class="text-2xl font-semibold tracking-tight text-foreground">
            {avatar.name}
          </h1>
          <p class="text-sm text-muted-foreground">{avatar.tagline}</p>
        </div>
      </div>

      <!-- 右侧词条 -->
      <ul class="order-3 flex flex-col gap-3 md:items-start">
        {info.right.map((item, i) => (
          <InfoCard item={item} side="right" index={i} client:load />
        ))}
      </ul>
    </div>

    <!-- 一言打字效果 -->
    {
      hitokoto.enabled && (
        <div class="mt-12 flex min-h-[2rem] w-full max-w-2xl items-center justify-center px-4 text-center animate-in fade-in slide-in-from-bottom-3 duration-700 fill-mode-both [animation-delay:700ms]">
          <Typewriter
            placeholder={hitokoto.placeholder}
            fallback={hitokoto.fallback}
            typeSpeed={hitokoto.typeSpeed}
            deleteSpeed={hitokoto.deleteSpeed}
            holdAfterTyped={hitokoto.holdAfterTyped}
            holdAfterDeleted={hitokoto.holdAfterDeleted}
            client:load
          />
        </div>
      )
    }

    <!-- 社交链接 -->
    {
      social.length > 0 && (
        <div class="mt-10 animate-in fade-in slide-in-from-bottom-3 duration-700 fill-mode-both [animation-delay:900ms]">
          <SocialLinks links={social} client:load />
        </div>
      )
    }
  </main>
</Layout>

<style>
  /* 头像悬浮光环呼吸动画 */
  .avatar-ring::before {
    content: "";
    position: absolute;
    inset: -8px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    animation: ring-breathe 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes ring-breathe {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.9;
    }
  }

  /* 打字光标闪烁 */
  :global(.typewriter-cursor.is-blink) {
    animation: cursor-blink 1.05s steps(1) infinite;
  }

  @keyframes cursor-blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }
</style>
