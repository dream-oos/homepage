---
/**
 * 博客列表页
 *
 * 展示所有已发布的博客文章，并提供标签筛选、搜索与分页。
 * 交互逻辑由 React 岛屿 BlogExplorer 承担；本页在构建期将文章映射为
 * 可序列化的 PostSummary[] 与标签列表传入。初始状态（无筛选、第 1 页）
 * 经 SSR 渲染进 HTML，挂载后再读取 URL 参数应用筛选。
 * @route /blog
 */

import Layout from "@/layouts/Layout.astro";
import BlogNav from "@/components/astro/BlogNav.astro";
import BlogExplorer from "@/components/react/BlogExplorer.tsx";
import { getPublishedPosts, toSummary, getTagsWithCount } from "@/lib/blog";
import { getSiteConfig } from "@/lib/site";

const { site } = getSiteConfig();
const posts = await getPublishedPosts();
const summaries = posts.map(toSummary);
const tags = getTagsWithCount(posts);
---

<Layout
  title={`${site.title} · 博客`}
  description="字里行间的裂隙——技术、设计与生活的记录"
>
  <BlogNav current="blog" />

  <main class="relative pt-12">
    <!-- 页眉 -->
    <div class="border-border/40 border-b">
      <div class="mx-auto max-w-2xl px-6 py-16">
        <p
          class="text-muted-foreground mb-2 text-[10px] tracking-[0.2em] uppercase"
        >
          博客 / Blog
        </p>
        <h1
          class="font-heading text-foreground text-3xl font-semibold tracking-tight"
        >
          字里行间的裂隙
        </h1>
        <p class="text-muted-foreground mt-2 text-sm">
          技术、设计与生活的零散记录
        </p>
      </div>
      <!-- 裂隙装饰线 -->
      <div class="rift-line h-0.5 w-full"></div>
    </div>

    <!-- 文章列表 + 筛选 / 搜索 / 分页 -->
    <div class="mx-auto max-w-2xl px-6 py-12">
      <BlogExplorer posts={summaries} {tags} client:load />
    </div>
  </main>
</Layout>
