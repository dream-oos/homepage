---
/**
 * 博客文章详情页
 *
 * 动态路由，为每篇已发布的文章生成独立页面。
 * @route /blog/:slug
 */

import Layout from "@/layouts/Layout.astro";
import BlogNav from "@/components/astro/BlogNav.astro";
import Comments from "@/components/react/Comments.tsx";
import CodeBlockEnhancer from "@/components/react/CodeBlockEnhancer.tsx";
import ReadingNav from "@/components/react/ReadingNav.tsx";
import { getPublishedPosts, formatDate, readingTime } from "@/lib/blog";
import { getSiteConfig } from "@/lib/site";
import { render } from "astro:content";
import type { BlogPost } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: BlogPost };
const { Content, headings } = await render(post);
const minutes = readingTime(post.body ?? "");
const { comments } = getSiteConfig();
---

<Layout title={`${post.data.title} · 博客`} description={post.data.description}>
  <BlogNav current="blog" />

  <main class="relative pt-12">
    <article class="mx-auto max-w-2xl px-6 py-16">
      <!-- 文章头部 -->
      <header>
        <div class="flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          <span aria-hidden="true">&middot;</span>
          <span>{minutes} 分钟阅读</span>
          {post.data.tags.length > 0 && (
            <>
              <span aria-hidden="true">&middot;</span>
              <ul class="flex flex-wrap gap-1.5">
                {post.data.tags.map((tag: string) => (
                  <li
                    class="rounded-full border border-border/40 bg-card px-2 py-0.5 text-[10px] uppercase tracking-[0.08em] text-muted-foreground"
                  >
                    {tag}
                  </li>
                ))}
              </ul>
            </>
          )}
        </div>
        <h1 class="mt-4 font-heading text-3xl font-semibold tracking-tight text-foreground">
          {post.data.title}
        </h1>
        <p class="mt-2 text-sm text-muted-foreground">
          {post.data.description}
        </p>
      </header>

      <!-- 裂隙装饰线 -->
      <div class="rift-line my-10 h-0.5 w-full"></div>

      <!-- 文章正文 -->
      <div class="prose-rift">
        <Content />
      </div>

      <!-- 代码块增强：复制按钮 + 长代码折叠 -->
      <CodeBlockEnhancer client:load />

      <!-- 返回链接 -->
      <div class="mt-16 border-t border-border/40 pt-8">
        <a
          href="/blog"
          class="inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-accent"
        >
          <span aria-hidden="true">&larr;</span>
          返回博客
        </a>
      </div>

      <!-- 评论系统（滚动进入视口后懒加载） -->
      <Comments config={comments} client:visible />
    </article>
  </main>

  <!-- 阅读导航：右下角悬浮目录 + 回到顶部 -->
  <ReadingNav headings={headings} client:load />
</Layout>

<style>
  .rift-line {
    background: conic-gradient(
      from var(--rift-angle, 0deg),
      oklch(0.58 0.22 18),
      oklch(0.72 0.12 180),
      oklch(0.58 0.22 18)
    );
    animation: rift-spin 8s linear infinite;
  }

  @keyframes rift-spin {
    to {
      --rift-angle: 360deg;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rift-line {
      animation: none;
    }
  }
</style>

<style is:global>
  /* ===== Prose styling for blog content ===== */
  /* 锚点跳转预留顶栏高度，避免标题被固定导航栏遮挡 */
  .prose-rift :is(h2, h3, h4) {
    scroll-margin-top: 4.5rem;
  }

  .prose-rift h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-left: 0.75rem;
    border-left: 3px solid var(--primary, oklch(0.58 0.22 18));
    color: var(--foreground, oklch(0.93 0.01 90));
  }

  .prose-rift h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--foreground, oklch(0.93 0.01 90));
  }

  .prose-rift p {
    color: color-mix(in oklch, var(--foreground, oklch(0.93 0.01 90)) 85%, transparent);
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .prose-rift a {
    color: var(--accent, oklch(0.72 0.12 180));
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s;
  }

  .prose-rift a:hover {
    opacity: 0.8;
  }

  .prose-rift ul,
  .prose-rift ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: color-mix(in oklch, var(--foreground, oklch(0.93 0.01 90)) 85%, transparent);
    line-height: 1.75;
  }

  .prose-rift ul {
    list-style-type: disc;
  }

  .prose-rift ol {
    list-style-type: decimal;
  }

  .prose-rift li {
    margin-bottom: 0.25rem;
  }

  .prose-rift li::marker {
    color: var(--primary, oklch(0.58 0.22 18));
  }

  .prose-rift blockquote {
    border-left: 3px solid var(--primary, oklch(0.58 0.22 18));
    background: color-mix(in oklch, var(--card, oklch(0.17 0.02 270)) 40%, transparent);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    color: color-mix(in oklch, var(--foreground, oklch(0.93 0.01 90)) 75%, transparent);
    font-style: italic;
  }

  .prose-rift blockquote p:last-child {
    margin-bottom: 0;
  }

  .prose-rift code:not(pre code) {
    background: var(--muted, oklch(0.20 0.02 270));
    color: var(--primary, oklch(0.58 0.22 18));
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.8125rem;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
  }

  .prose-rift pre {
    background: var(--card, oklch(0.17 0.02 270));
    border: 1px solid var(--border, oklch(0.24 0.02 270));
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    line-height: 1.6;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
  }

  .prose-rift pre code {
    background: none;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  /* ===== 代码块增强（复制 + 折叠） ===== */
  .code-block-wrapper {
    position: relative;
    margin: 1.5rem 0;
  }

  /* 包装后 pre 自身不再需要外边距，由 wrapper 统一控制 */
  .code-block-wrapper > pre {
    margin: 0;
  }

  /* 可折叠块：为底部折叠按钮预留空间，避免遮挡最后一行代码 */
  .code-block-wrapper.is-collapsible > pre {
    padding-bottom: 3rem;
  }

  /* 折叠态：限制可见高度（仅纵向裁剪，横向仍可滚动） */
  .code-block-wrapper.is-collapsible.is-collapsed > pre {
    max-height: 300px;
    overflow-y: hidden;
  }

  /* 工具栏（复制）按钮默认半透明，悬浮容器时显现 */
  .code-block-toolbar button {
    opacity: 0;
    transition: opacity 0.2s, background-color 0.2s, color 0.2s;
  }

  .code-block-wrapper:hover .code-block-toolbar button,
  .code-block-wrapper:focus-within .code-block-toolbar button {
    opacity: 1;
  }

  /* 折叠态底部半透明遮罩 —— 不完全遮死，隐约透出下方代码 */
  .code-block-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 7.5rem;
    border-radius: 0 0 0.75rem 0.75rem;
    background: linear-gradient(
      to bottom,
      transparent,
      color-mix(in oklch, var(--card, oklch(0.17 0.02 270)) 68%, transparent) 55%,
      color-mix(in oklch, var(--card, oklch(0.17 0.02 270)) 86%, transparent)
    );
    -webkit-backdrop-filter: blur(2px);
    backdrop-filter: blur(2px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .code-block-wrapper.is-collapsed .code-block-fade {
    opacity: 1;
  }

  /* 展开时隐藏遮罩 */
  .code-block-wrapper:not(.is-collapsed) .code-block-fade {
    display: none;
  }

  .prose-rift hr {
    border: none;
    height: 2px;
    background: conic-gradient(
      from var(--rift-angle, 0deg),
      oklch(0.58 0.22 18),
      oklch(0.72 0.12 180),
      oklch(0.58 0.22 18)
    );
    animation: rift-spin 8s linear infinite;
    margin: 2.5rem 0;
  }

  .prose-rift img {
    border-radius: 0.75rem;
    border: 1px solid var(--border, oklch(0.24 0.02 270));
    max-width: 100%;
    height: auto;
  }

  .prose-rift strong {
    color: var(--foreground, oklch(0.93 0.01 90));
    font-weight: 600;
  }

  .prose-rift table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }

  .prose-rift th,
  .prose-rift td {
    border: 1px solid var(--border, oklch(0.24 0.02 270));
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .prose-rift th {
    background: var(--muted, oklch(0.20 0.02 270));
    font-weight: 600;
    color: var(--foreground, oklch(0.93 0.01 90));
  }

  .prose-rift td {
    color: color-mix(in oklch, var(--foreground, oklch(0.93 0.01 90)) 85%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .prose-rift hr {
      animation: none;
    }
  }

  /* ===== 评论系统主题适配 =====
     Waline / Twikoo 各自注入 DOM，样式无法走 Astro 作用域，故在此全局覆盖。
     通过它们暴露的 CSS 变量对齐站点裂隙配色，避免覆盖内部类名，
     降低随版本升级而失效的风险。两者 dark 模式由 Comments 组件传入
     dark:'html.dark' 跟随站点切换。 */
  .comments-rift {
    /* Waline —— 主色 → 裂隙红，交互色 → 维度青 */
    --waline-theme-color: var(--primary);
    --waline-active-color: var(--accent);
    --waline-bg-color: var(--card);
    --waline-bg-color-light: var(--muted);
    --waline-border-color: var(--border);
    --waline-font-color: var(--foreground);
    --waline-color: var(--muted-foreground);
    --waline-disable-bg-color: var(--muted);
    --waline-disable-color: var(--muted-foreground);
  }

  /* 暗色模式补齐 Waline 的 dark 主题变量 */
  html.dark .comments-rift {
    --waline-bg-color-light: oklch(0.20 0.02 270);
  }

  /* Waline：输入框圆角与站点卡片一致 */
  .comments-rift .wl-header .wl-input,
  .comments-rift .wl-editor {
    border-radius: var(--radius);
  }

  /* Twikoo —— 对齐输入框与按钮圆角、边框，使其与站点控件一致 */
  .comments-rift .tk-input,
  .comments-rift .tk-textarea {
    border-radius: var(--radius);
    border-color: var(--border);
    background: var(--card);
    color: var(--foreground);
  }

  .comments-rift .tk-input:focus {
    border-color: var(--accent);
  }

  .comments-rift .tk-btn {
    border-radius: var(--radius);
    background: var(--primary);
    color: var(--primary-foreground);
  }

  .comments-rift .tk-submit .tk-btn:hover {
    opacity: 0.85;
  }

  .comments-rift .comments-container {
    min-height: 2rem;
  }
</style>
